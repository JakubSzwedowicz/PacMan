@startuml PackageDiagram
skinparam componentStyle uml2
top to bottom direction

!include package_parts/_client.iuml
!include package_parts/_server.iuml
!include package_parts/_core.iuml
!include package_parts/_externals.iuml

' --- Layout ---
ClientPkg -[hidden]down-> CorePkg
ServerPkg -[hidden]down-> CorePkg
CorePkg -[hidden]down-> ExtPkg

' --- Client → Core ---
[ClientApp] --> [Simulation]
[Renderer] ..> [Components]
[ClientNetwork] ..> [ProtocolDefinitions]

' --- Server → Core ---
[ServerApp] --> [Simulation]
[ServerNetwork] ..> [ProtocolDefinitions]
[AuthoritativeLogic] ..> [Components]
[AISystem] ..> [Components]

' --- Core → External ---
[Simulation] ..> [EnTT] : ECS
[MapsManager] ..> [Glaze] : Map JSON
[ProtocolDefinitions] ..> [FlatBuffers] : Protocol

' --- Client → External ---
[Renderer] ..> [SFML] : Graphics
[Window] ..> [SFML] : Window
[InputManager] ..> [SFML] : Input
[ClientNetwork] ..> [ENet] : UDP
[UIOverlay] ..> [ImGui-SFML] : UI

' --- Server → External ---
[ServerNetwork] ..> [ENet] : UDP

' --- Logging ---
CorePkg ..> [SpdLog] : Logging

@enduml
