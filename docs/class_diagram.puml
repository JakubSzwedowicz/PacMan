@startuml ClassDiagram
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "Utils (vcpkg)" <<Rectangle>> {
    abstract class "IPublisher<M>" as IPublisher {
        #publish(message)
    }
    abstract class "ISubscriber<M>" as ISubscriber {
        +{abstract} onUpdate(message)
    }
}

package Core <<Rectangle>> {
    class Simulation {
        +applyInput(registry, entityId, input)
        +update(registry, dt)
    }
    class MapsManager {
        +loadFromFile(path) : Map
        +loadFromJson(json) : Map
    }
    class Map <<Glaze>> {
        name, width, height, tileSize
        tiles, pacmanSpawns, ghostSpawns
    }
    class Input <<POD>> {
        tick : uint32
        dir : Direction
    }
    class ProtocolDefinitions <<FlatBuffers>>

    package "ECS" {
        class Components <<POD>> {
            Position { x, y }
            Velocity { speed }
            Direction { current, next }
            Collider { width, height }
            PlayerState { score, lives, isPowered }
            GhostState { mode }
        }
        class MarkerTags <<empty>> {
            PacManTag
            GhostTag
            PelletTag
            PowerPelletTag
            WallTag
        }
        class MovementSystem {
            +update(registry, dt)
        }
        class CollisionSystem {
            +update(registry)
        }
    }

    Simulation ..> Components
    Simulation ..> MovementSystem
    Simulation ..> CollisionSystem
    MapsManager ..> Map
}

package Client <<Rectangle>> {
    class ClientApp {
        -window : Window
        -screenManager : ScreenManager
        -inputManager : InputManager
        -clientNetwork : ClientNetwork
        -renderer : Renderer
        -uiOverlay : UIOverlay
        +run()
    }
    class Window {
        -renderWindow : sf::RenderWindow
        +pollEvents()
        +display()
    }
    class ScreenManager {
        -currentScreen : unique_ptr<Screen>
        +setScreen(screen)
    }
    abstract class Screen {
        +{abstract} onEnter()
        +{abstract} onExit()
        +{abstract} handleInput(input)
        +{abstract} update(dt)
        +{abstract} draw(renderer)
    }
    class Renderer {
        +draw(registry, window)
    }
    class InputManager {
        +poll() : Input
    }
    class ClientNetwork {
        -jitterBuffer : deque<Snapshot>
        +connect(ip, port)
        +poll()
        +send(packet)
    }
    class UIOverlay {
        +drawMenu()
        +drawHUD()
        +drawDebug()
    }

    package "Screens" {
        class MenuScreen
        class LobbyScreen
        class LoadingScreen
        class GameScreen
    }

    ' Client internal relations
    ClientApp *-- Window
    ClientApp *-- ScreenManager
    ClientApp *-- InputManager
    ClientApp *-- ClientNetwork
    ClientApp *-- Renderer
    ClientApp *-- UIOverlay

    ScreenManager o-- Screen
    Screen <|-- MenuScreen
    Screen <|-- LobbyScreen
    Screen <|-- LoadingScreen
    Screen <|-- GameScreen

    ClientApp ..> "Core::Simulation"
    InputManager ..> "Core::Input"

    Renderer ..> "Core::Components"
    Renderer ..> "Core::MapsManager"
    ClientNetwork ..> "Core::ProtocolDefinitions"

    GameScreen ..> "Core::Simulation"
    GameScreen ..> "Core::Components"

    ' Pub-Sub: ClientNetwork publishes, Screens subscribe
    ClientNetwork ..|> "IPublisher" : publishes\nLobbyUpdate,\nGameInit,\nSnapshot
    LobbyScreen ..|> "ISubscriber" : subscribes\nLobbyUpdate
    LoadingScreen ..|> "ISubscriber" : subscribes\nGameInit
    GameScreen ..|> "ISubscriber" : subscribes\nSnapshot
}

package Server <<Rectangle>> {
    class ServerApp {
        -serverNetwork : ServerNetwork
        -authoritativeLogic : AuthoritativeLogic
        -currentPhase : Phase
        +run()
    }
    class ServerNetwork {
        +host(port)
        +poll()
        +broadcast(packet)
        +send(peerId, packet)
    }
    class AuthoritativeLogic {
        -aiSystem : AISystem
        +validateInput(input) : bool
        +resolveGameRules(registry)
    }
    class AISystem {
        +updateGhosts(registry)
    }

    package "Phases" {
        class LobbyPhase {
            +onEnter()
            +update()
            +onExit()
        }
        class GamePhase {
            +onEnter()
            +update()
            +onExit()
        }
    }

    ' Server internal relations
    ServerApp *-- ServerNetwork
    ServerApp *-- AuthoritativeLogic
    AuthoritativeLogic *-- AISystem

    ServerApp o-- LobbyPhase
    ServerApp o-- GamePhase

    ServerApp ..> "Core::Simulation"
    ServerNetwork ..> "Core::ProtocolDefinitions"
    AuthoritativeLogic ..> "Core::Components"
    AISystem ..> "Core::Components"

    GamePhase ..> "Core::Simulation"
    GamePhase ..> "Core::Components"

    ' Pub-Sub: ServerNetwork publishes, Phases subscribe
    ServerNetwork ..|> "IPublisher" : publishes\nincoming packets
    LobbyPhase ..|> "ISubscriber" : subscribes\nconnection events
    GamePhase ..|> "ISubscriber" : subscribes\nInputPacket
}

@enduml
