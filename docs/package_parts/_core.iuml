package "Core (src/core/)" as CorePkg {
    [Simulation]
    [MapsManager]
    [ProtocolDefinitions]

    package "ECS (ecs/)" {
        [Components]
        [MovementSystem]
        [CollisionSystem]
    }

    [Simulation] ..> [Components]
    [Simulation] ..> [MovementSystem]
    [Simulation] ..> [CollisionSystem]
}
