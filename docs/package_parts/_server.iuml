package "Server (src/server/)" as ServerPkg {
    package "app/" {
        [ServerApp]
    }

    package "network/" {
        [ServerNetwork]
        [INetworkEventHandler]
    }

    package "ai/" {
        [AISystem]
        [GhostPhaseTimer]
        [GhostBehavior]
    }

    package "phases/" {
        [Phase]
        [LobbyPhase]
        [GamePhase]
    }

    [ServerApp] --> [ServerNetwork] : owns
    [ServerApp] --> [Phase] : owns (current/pending)

    [LobbyPhase] ..|> [Phase]
    [LobbyPhase] ..|> [INetworkEventHandler]
    [GamePhase]  ..|> [Phase]
    [GamePhase]  ..|> [INetworkEventHandler]

    [LobbyPhase] --> [ServerApp] : setPhase
    [GamePhase]  --> [ServerApp] : setPhase
    [GamePhase]  *-- [AISystem]

    [AISystem] *-- [GhostPhaseTimer]
    [AISystem] ..> [GhostBehavior]
}
